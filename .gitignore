# Shared config local overrides
shared/configs/local/

# Caddy data
vps/apps/caddy/data/

# Docker volumes (if using local bind mounts)
caddy_data/
caddy_config/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Node dependencies
node_modules/

# Frontend build output
apps/suite-manager/frontend/dist/
tests/e2e/node_modules/
tests/e2e/playwright-report/
tests/e2e/test-results/

# Self-host generated artifacts
deploy/self-host/autoinstall/generated/
deploy/self-host/autoinstall/ubuntu-iso/
deploy/self-host/output/

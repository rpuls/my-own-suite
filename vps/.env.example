# VPS Deployment Configuration
# Copy this file to .env and update values for your deployment

# ==================================
# Domain Configuration
# ==================================
# Your domain (without protocol)
DOMAIN=example.com

# Full base URL for services (with protocol)
BASE_URL=https://example.com

# ==================================
# Homepage Configuration
# ==================================
# Homepage allowed hosts (should match your domain)
HOMEPAGE_ALLOWED_HOSTS=example.com

# ==================================
# Vaultwarden Configuration
# ==================================
# Vaultwarden URL on your domain
VAULTWARDEN_URL=https://example.com/vaultwarden/

# Admin token for Vaultwarden (generate a secure token)
VAULTWARDEN_ADMIN_TOKEN=

# Allow new user signups (true/false)
VAULTWARDEN_SIGNUPS_ALLOWED=true

# ==================================
# Test/Development
# ==================================
# Optional test message (appears on homepage if set)
TEST_MESSAGE=
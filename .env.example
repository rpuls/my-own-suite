# My-Own-Suite Configuration
# Copy this file to vps/.env for VPS deployment
# For Railway, set these variables in the Railway dashboard

# ===========================================
# General Configuration
# ===========================================

# Your public domain (used by all services)
DOMAIN=http://localhost

# Email for SSL certificates (VPS/Caddy)
EMAIL=admin@example.com

# ===========================================
# Vaultwarden Settings
# ===========================================

# Admin panel access token (generate with: openssl rand -base64 48)
VAULTWARDEN_ADMIN_TOKEN=

# Allow new user registrations (set to false after creating your account)
VAULTWARDEN_SIGNUPS_ALLOWED=true

# ===========================================
# Railway-Specific Variables
# ===========================================
# These are set in Railway dashboard, not in this file

# DATABASE_URL - PostgreSQL connection string
#   Railway auto-generates this when you connect a PostgreSQL database
#   Reference: ${{Postgres.DATABASE_URL}}

# RAILWAY_PUBLIC_DOMAIN - Your Railway public domain
#   Railway auto-populates this variable
#   Use: https://${{RAILWAY_PUBLIC_DOMAIN}}

# VAULTWARDEN_URL - URL to Vaultwarden (for Homepage service)
#   Set to your deployed Vaultwarden service URL
#   Example: https://your-vaultwarden.up.railway.app
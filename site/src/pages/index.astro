---
import { GITHUB_REPO_URL, WAITLIST_MAILTO } from '../lib/links'
import '../styles/site.css'

const logoModules = import.meta.glob('../assets/logos/*.{png,jpg,jpeg,svg,webp,avif}', { eager: true })
const normalizeLogoName = (name: string) => {
  return name
    .replace(/[-_]/g, ' ')
    .replace(/\s+/g, ' ')
    .replace(/\b(white|black|grey|gray|light|dark|logo)\b/gi, '')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/\b\w/g, (char) => char.toUpperCase())
}

const getImageSrc = (mod: unknown) => {
  const resolved = (mod as { default?: unknown }).default ?? mod
  if (typeof resolved === 'string') {
    return resolved
  }
  if (resolved && typeof resolved === 'object' && 'src' in resolved) {
    const src = (resolved as { src?: unknown }).src
    if (typeof src === 'string') {
      return src
    }
  }
  return ''
}

const appLogos = Object.entries(logoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const fileName = path.split('/').pop() ?? ''
    const baseName = fileName.replace(/\.[^.]+$/, '')
    const alt = normalizeLogoName(baseName)

    return {
      src: getImageSrc(mod),
      alt
    }
  })
  .filter((logo) => logo.src.length > 0)
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>My Own Suite</title>
    <meta
      name='description'
      content='Your Big Tech exit kit: open‑source, self‑hosted tools that let individuals, families, and freelancers replace Google, Apple, and Microsoft services with a private cloud they own.'
    />
  </head>
  <body>
    <main class='landing'>
      <section class='hero container'>
        <h1>My Own Suite</h1>
        <p class='tagline'>Your Big Tech exit kit.</p>
        <p class='slideshow' aria-live='polite'>
          <span class='slideshow-line' data-slideshow-line>Planning your Gexit?</span>
        </p>

        <div class='cta-row'>
          <span
            class='btn btn-primary btn-disabled'
            role='button'
            aria-disabled='true'
            tabindex='0'
            data-tooltip='This repo is under construction and not yet open to the public.'
            aria-label='This repo is under construction and not yet open to the public.'
          >
            Follow on GitHub
          </span>
          <a class='btn btn-secondary' href={WAITLIST_MAILTO} target='_blank' rel='noreferrer'>
            Join the waitlist
          </a>
        </div>
        <p class='coming-soon'>Coming soon</p>
      </section>

      <section class='container accordion' aria-label='More details'>
        <details class='accordion-item'>
          <summary>What is My Own Suite?</summary>
          <ul>
            <li>A Swiss army knife of self‑hosted digital tools.</li>
            <li>Your digital life, in a cloud that you own and control.</li>
            <li>Open‑source replacements for your everyday apps — without Big Tech in the middle.</li>
            <li>Easy setup, no IT degree needed.</li>
            <li>Modular design: run only what you need.</li>
          </ul>
        </details>

        <details class='accordion-item'>
          <summary>Who is My Own Suite for?</summary>
          <ul>
            <li>People who want to leave Google, Apple, and Microsoft — without losing convenience.</li>
            <li>Freelancers and creators who refuse to have their work used to train AI models.</li>
            <li>Individuals tired of trading privacy for “free” cloud services.</li>
            <li>Families who want their photos and private moments to stay private.</li>
            <li>Curious minds who like open‑source, privacy, and a touch of rebellion.</li>
          </ul>
        </details>
      </section>
    </main>

    <footer class='site-footer container'>
      <section class='attribution' aria-label='Attribution'>
        <p class='attribution-label'>Made with</p>
        <div class='logo-marquee' aria-label='Included apps'>
          <div class='logo-track'>
            {appLogos.map((logo) => (
              <img class='app-logo' src={logo.src} alt={logo.alt} loading='lazy' decoding='async' />
            ))}
            {appLogos.map((logo) => (
              <img class='app-logo' src={logo.src} alt={logo.alt} aria-hidden='true' loading='lazy' decoding='async' />
            ))}
          </div>
        </div>
        <p class='attribution-label'>Bundled by</p>
        <a
          class='made-by'
          href='https://funkyton.com/'
          target='_blank'
          rel='noreferrer'
          aria-label='Bundled by Funkyton'
        >
          <img
            class='site-logo'
            src='https://res-5.cloudinary.com/hczpmiapo/image/upload/q_auto/v1/ghost-blog-images/funkyton-logo.png'
            alt='Funkyton'
            loading='lazy'
            decoding='async'
          />
        </a>
      </section>
    </footer>
    <nav aria-label='Footer links' class='footer-links-corner'>
      <a href='/docs'>Docs</a>
      <span
        class='footer-link-disabled'
        role='link'
        aria-disabled='true'
        tabindex='0'
        data-tooltip='This repo is under construction and not yet open to the public.'
        aria-label='This repo is under construction and not yet open to the public.'
      >
        GitHub
      </span>
    </nav>

    <script>
      const lines = [
        'Planning your Gexit?',
        'Ever thought about Mexit?',
        'Need help with Aexit?'
      ]

      const lineEl = document.querySelector('[data-slideshow-line]')

      if (lineEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let index = 0

        setInterval(() => {
          lineEl.classList.add('is-leaving')

          setTimeout(() => {
            index = (index + 1) % lines.length
            lineEl.textContent = lines[index]
            lineEl.classList.remove('is-leaving')
            lineEl.classList.add('is-entering')

            requestAnimationFrame(() => {
              lineEl.classList.remove('is-entering')
            })
          }, 220)
        }, 2800)
      }

      const items = document.querySelectorAll('.accordion-item')

      items.forEach((item) => {
        item.addEventListener('toggle', () => {
          if (!item.open) {
            return
          }

          items.forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.open = false
            }
          })
        })
      })
    </script>
  </body>
</html>


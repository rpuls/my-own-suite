---
import MadeWithCarousel from '../components/landing/MadeWithCarousel.astro'
import { GITHUB_REPO_URL, WAITLIST_MAILTO } from '../lib/links'
import '../styles/site.css'
import homepageLogo from '../assets/logos/homepage.png'
import immichLogo from '../assets/logos/immich.png'
import onlyofficeLogo from '../assets/logos/ONLYOFFICE.png'
import radicaleLogo from '../assets/logos/radicale.png'
import seafileLogo from '../assets/logos/seafile.png'
import stirlingPdfLogo from '../assets/logos/stirling-pdf.png'
import vaultwardenLogo from '../assets/logos/vaultwarden.png'
import mosMark from '../assets/brand/my-own-suite-mark.png'

const logoModules = import.meta.glob('../assets/logos/*.{png,jpg,jpeg,svg,webp,avif}', { eager: true })

const normalizeLogoName = (name: string) => {
  return name
    .replace(/[-_]/g, ' ')
    .replace(/\s+/g, ' ')
    .replace(/\b(white|black|grey|gray|light|dark|logo)\b/gi, '')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/\b\w/g, (char) => char.toUpperCase())
}

const getImageSrc = (mod: unknown) => {
  const resolved = (mod as { default?: unknown }).default ?? mod
  if (typeof resolved === 'string') {
    return resolved
  }
  if (resolved && typeof resolved === 'object' && 'src' in resolved) {
    const src = (resolved as { src?: unknown }).src
    if (typeof src === 'string') {
      return src
    }
  }
  return ''
}

const appLogos = Object.entries(logoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const fileName = path.split('/').pop() ?? ''
    const baseName = fileName.replace(/\.[^.]+$/, '')
    const alt = normalizeLogoName(baseName)

    return {
      src: getImageSrc(mod),
      alt
    }
  })
  .filter((logo) => logo.src.length > 0)

const modules = [
  {
    title: 'Files and sync',
    app: 'Seafile',
    href: '/docs/apps/seafile',
    logo: seafileLogo.src,
    logoAlt: 'Seafile logo',
    body: 'Private cloud storage, sync, sharing, and libraries across your devices.'
  },
  {
    title: 'Documents and spreadsheets',
    app: 'ONLYOFFICE',
    href: '/docs/apps/onlyoffice',
    logo: onlyofficeLogo.src,
    logoAlt: 'ONLYOFFICE logo',
    body: 'Browser-based editing for docs, sheets, presentations, and team-friendly workflows.'
  },
  {
    title: 'Photos and memories',
    app: 'Immich',
    href: '/docs/apps/immich',
    logo: immichLogo.src,
    logoAlt: 'Immich logo',
    body: 'Self-hosted photo backup and a private library for everyday image and video life.'
  },
  {
    title: 'Passwords',
    app: 'Vaultwarden',
    href: '/docs/apps/vaultwarden',
    logo: vaultwardenLogo.src,
    logoAlt: 'Vaultwarden logo',
    body: 'Secure password storage and autofill without handing your vault to a hosted consumer platform.'
  },
  {
    title: 'Calendars',
    app: 'Radicale',
    href: '/docs/apps/radicale',
    logo: radicaleLogo.src,
    logoAlt: 'Radicale logo',
    body: 'Private calendar sync that works with the devices and clients you already use.'
  },
  {
    title: 'PDF tools',
    app: 'Stirling PDF',
    href: '/docs/apps/stirling-pdf',
    logo: stirlingPdfLogo.src,
    logoAlt: 'Stirling PDF logo',
    body: 'Merge, split, convert, and process PDFs inside your own stack.'
  },
  {
    title: 'Dashboard',
    app: 'Homepage',
    href: '/docs/apps/homepage',
    logo: homepageLogo.src,
    logoAlt: 'Homepage logo',
    body: 'One starting point for opening the suite and moving between modules quickly.'
  },
  {
    title: 'Control plane',
    app: 'Suite Manager',
    href: '/docs/getting-started',
    logo: mosMark.src,
    logoAlt: 'My Own Suite logo',
    body: 'Guided onboarding, first-run access, and the entrypoint that turns the bundle into a usable product.'
  }
]

const steps = [
  {
    title: 'Choose your deploy style',
    body: 'Start on Railway for the easiest path, use a VPS for more hosting freedom, or run it on your own hardware.',
    href: '/docs/getting-started',
    label: 'Explore deploy options'
  },
  {
    title: 'Deploy the suite',
    body: 'Bring up the curated stack with the documented setup flow instead of manually assembling each app yourself.',
    href: '/docs/deploy-on-railway',
    label: 'Read the quickest path'
  },
  {
    title: 'Finish onboarding and use it',
    body: 'Sign in through Suite Manager, land on Homepage, and start using the apps as one connected setup.',
    href: '/docs',
    label: 'See the overview'
  }
]

const principles = [
  {
    title: 'Not a closed platform',
    body: 'My Own Suite bundles open tools together. It does not try to trap your data inside one vendor-owned ecosystem.'
  },
  {
    title: 'Portable by design',
    body: 'Railway can be the easy start, but the long-term story is choice: different hosts, a VPS, or your own hardware.'
  },
  {
    title: 'Technical, but approachable',
    body: 'The stack is real and modular under the hood, while the public docs and onboarding aim to keep the learning curve humane.'
  }
]
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>My Own Suite</title>
    <meta name='theme-color' content='#061526' />
    <meta
      name='description'
      content='My Own Suite is a modular self-hosted Big Tech exit kit: a curated bundle of open-source apps you control, with docs and deploy paths for Railway, VPS, and your own hardware.'
    />
    <link rel='icon' href='/favicon.ico' sizes='any' />
    <link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
    <link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
    <link rel='apple-touch-icon' sizes='180x180' href='/apple-touch-icon.png' />
    <link rel='manifest' href='/site.webmanifest' />
  </head>
  <body>
    <main class='landing-page'>
      <div class='site-header-wrap'>
        <header class='site-header nav-shell'>
          <a class='brand' href='/' aria-label='My Own Suite home'>
            <img src='/brand/my-own-suite-mark.png' alt='' width='42' height='42' decoding='async' />
            <span class='brand-copy'>
              <strong>My Own Suite</strong>
              <span>Your Big Tech exit kit</span>
            </span>
          </a>

          <nav class='header-nav' aria-label='Primary'>
            <a href='/docs'>Docs</a>
            <a href={GITHUB_REPO_URL} target='_blank' rel='noreferrer'>GitHub</a>
            <a class='mos-btn mos-btn-secondary header-cta secondary' href={WAITLIST_MAILTO} target='_blank' rel='noreferrer'>
              Waitlist
            </a>
            <a class='mos-btn mos-btn-primary header-cta' href='/docs/getting-started'>Get started</a>
          </nav>
        </header>
      </div>

      <section class='hero section'>
        <div class='shell hero-grid'>
          <div class='hero-copy'>
            <h1>Take back control of your digital life.</h1>
            <p class='hero-lead mos-body-lg'>
              My Own Suite gives you your own versions of the apps you use every day, like files, photos, documents,
              calendars, and passwords, without relying on Big Tech.
            </p>
            <p class='hero-support mos-body'>
              Today, your data lives inside services you don't control. The rules can change, privacy is uncertain,
              and your information is often treated as a product. You shouldn't have to trade ownership for
              convenience.
            </p>
            <p class='hero-support mos-body'>
              My Own Suite brings these tools together into one simple setup that you can run on your own terms, so
              everything stays yours without feeling complicated or pieced together.
            </p>

            <div class='hero-actions'>
              <a class='mos-btn mos-btn-primary' href='/docs/getting-started'>Read the docs</a>
            </div>
          </div>

          <div class='hero-visual' aria-hidden='true'>
            <div class='hero-network mos-panel'>
              <div class='network-orbit orbit-one'></div>
              <div class='network-orbit orbit-two'></div>
              <div class='network-core'>
                <img src='/brand/my-own-suite-mark.png' alt='' width='96' height='96' />
                <span>Core suite</span>
              </div>
              <div class='network-node node-files'>
                <strong>Files</strong>
                <span>Seafile</span>
              </div>
              <div class='network-node node-office'>
                <strong>Docs</strong>
                <span>ONLYOFFICE</span>
              </div>
              <div class='network-node node-photos'>
                <strong>Photos</strong>
                <span>Immich</span>
              </div>
              <div class='network-node node-passwords'>
                <strong>Passwords</strong>
                <span>Vaultwarden</span>
              </div>
              <div class='network-node node-calendar'>
                <strong>Calendar</strong>
                <span>Radicale</span>
              </div>
              <div class='network-node node-pdf'>
                <strong>PDF</strong>
                <span>Stirling PDF</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class='trust-strip section' aria-label='Suite apps'>
        <div class='shell section-heading suite-tools-copy'>
          <h2 class='mos-section-title'>Built on proven tools, not reinvented ones</h2>
          <p class='mos-body'>
            My Own Suite is built by bringing together some of the best open-source tools available today. Each one is
            widely used, actively maintained, and chosen because it is the best in its category.
          </p>
        </div>

        <div class='shell suite-tools-grid'>
          {modules.map((module) => (
            <a class='suite-tool-card mos-panel' href={module.href}>
              <div class='suite-tool-header'>
                <img src={module.logo} alt={module.logoAlt} width='56' height='56' loading='lazy' decoding='async' />
                <div>
                  <h3 class='mos-card-title'>{module.app}</h3>
                  <p class='suite-tool-category mos-small'>{module.title}</p>
                </div>
              </div>
              <p class='suite-tool-body mos-body'>{module.body}</p>
            </a>
          ))}
        </div>
      </section>

      <section class='section private-cloud-section'>
        <div class='shell private-cloud-grid'>
          <div class='private-cloud-copy'>
            <h2 class='mos-section-title'>Install once. Use it everywhere.</h2>
            <p class='mos-body'>
              With My Own Suite, you don't set up apps on every device. You deploy it once, and your apps run in your
              own private cloud.
            </p>
            <p class='mos-body'>
              That means your files, photos, documents, and tools are always available through your browser - on your
              laptop, phone, or tablet - just like the services you already use today.
            </p>
            <p class='mos-body'>
              And when you need it, you can still use native apps and sync clients for deeper integration, just like
              you would with services like Google Drive or iCloud.
            </p>
            <ul class='private-cloud-points'>
              <li>Open your suite from any browser, on any device</li>
              <li>Your apps and data stay in one place, always in sync</li>
              <li>Add native apps or sync clients when you want deeper integration</li>
            </ul>
          </div>

          <div class='private-cloud-visual' aria-hidden='true'>
            <svg class='private-cloud-diagram' viewBox='0 0 640 520' role='img' aria-label='My Own Suite cloud access diagram'>
              <defs>
                <filter id='mosSoftGlow' x='-50%' y='-50%' width='200%' height='200%'>
                  <feGaussianBlur stdDeviation='18' result='blur' />
                  <feMerge>
                    <feMergeNode in='blur' />
                    <feMergeNode in='SourceGraphic' />
                  </feMerge>
                </filter>
              </defs>

              <circle class='cloud-aura' cx='320' cy='118' r='108' />

              <g class='cloud-connectors'>
                <path d='M320 178 L180 282' />
                <path d='M320 178 L270 282' />
                <path d='M320 178 L400 292' />
                <path d='M320 178 L548 282' />
              </g>

              <g class='cloud-shape' filter='url(#mosSoftGlow)'>
                <path d='M241 164c-31 0-56-22-56-50s25-50 56-50h6c8-36 41-61 81-61 35 0 65 18 80 46a66 66 0 0 1 18-2c35 0 64 24 68 56 22 8 38 28 38 51 0 33-28 60-63 60H267c-17 0-28-2-37-9-10-7-16-18-16-33v-8Z' />
              </g>

              <image href='/brand/my-own-suite-mark.png' x='276' y='70' width='110' height='110' preserveAspectRatio='xMidYMid meet' />

              <g class='device device-phone' transform='translate(136 286)'>
                <rect class='device-shell' x='0' y='0' width='54' height='104' rx='18' />
                <rect class='device-screen' x='8' y='12' width='38' height='76' rx='10' />
                <rect class='screen-bar' x='14' y='20' width='18' height='4' rx='2' />
                <rect class='screen-chip accent' x='14' y='31' width='24' height='8' rx='4' />
                <rect class='screen-chip muted' x='14' y='44' width='20' height='8' rx='4' />
                <rect class='screen-chip soft' x='14' y='57' width='16' height='8' rx='4' />
                <circle class='device-dot' cx='27' cy='95' r='3' />
              </g>

              <g class='device device-tablet' transform='translate(226 272)'>
                <rect class='device-shell' x='0' y='0' width='96' height='126' rx='18' />
                <rect class='device-screen' x='10' y='12' width='76' height='102' rx='10' />
                <rect class='screen-bar' x='18' y='20' width='28' height='5' rx='2.5' />
                <rect class='screen-chip accent' x='18' y='34' width='44' height='10' rx='5' />
                <rect class='screen-chip muted' x='18' y='49' width='36' height='10' rx='5' />
                <rect class='screen-chip soft' x='18' y='64' width='52' height='10' rx='5' />
                <circle class='device-dot' cx='48' cy='120' r='3' />
              </g>

              <g class='device device-laptop' transform='translate(338 288)'>
                <rect class='device-shell' x='10' y='0' width='124' height='78' rx='12' />
                <rect class='device-screen' x='20' y='10' width='104' height='58' rx='8' />
                <rect class='screen-bar' x='30' y='19' width='30' height='5' rx='2.5' />
                <rect class='screen-chip accent' x='30' y='31' width='58' height='9' rx='4.5' />
                <rect class='screen-chip muted' x='30' y='45' width='44' height='9' rx='4.5' />
                <rect class='screen-chip soft' x='30' y='59' width='66' height='5' rx='2.5' />
                <path class='device-base' d='M0 88h144l-10 12H10Z' />
              </g>

              <g class='device device-desktop' transform='translate(500 278)'>
                <rect class='device-shell' x='0' y='0' width='96' height='74' rx='12' />
                <rect class='device-screen' x='10' y='10' width='76' height='54' rx='8' />
                <rect class='screen-bar' x='20' y='19' width='24' height='5' rx='2.5' />
                <rect class='screen-chip accent' x='20' y='31' width='40' height='9' rx='4.5' />
                <rect class='screen-chip muted' x='20' y='45' width='28' height='9' rx='4.5' />
                <rect class='device-stand' x='42' y='78' width='12' height='18' rx='6' />
                <rect class='device-base' x='28' y='94' width='40' height='8' rx='4' />
              </g>
            </svg>
          </div>
        </div>
      </section>

      <section class='section getting-started-section'>
        <div class='shell section-heading'>
          <h2 class='mos-section-title'>How do I get started?</h2>
          <p class='mos-body'>
            Because My Own Suite is built around control and independence, there isn’t just one way to use it. You can
            start simple or go deeper over time, depending on what feels right for you.
          </p>
        </div>

        <div class='shell getting-started-flow'>
          <article class='getting-started-card getting-started-primary mos-panel'>
            <div class='getting-started-content getting-started-columns'>
              <div class='getting-started-main'>
                <h3 class='mos-card-title'>Start in minutes</h3>
                <p class='mos-body'>
                  Run the suite using a ready-made deploy template with almost no setup. This is the easiest way to get
                  started and see how everything works. You trade some control for simplicity, but still get strong
                  privacy and a low-maintenance setup.
                </p>
                <a class='text-link mos-link' href='/docs/deploy-on-railway'>Start with Railway</a>
              </div>

              <div class='getting-started-metrics'>
                <div class='metric metric-text'>
                  <div class='metric-head'>
                    <span>Setup time</span>
                    <strong><span class='metric-icon' aria-hidden='true'>◷</span> Minutes</strong>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Privacy &amp; Control</span>
                    <small>75%</small>
                  </div>
                  <div class='continuous-meter' aria-hidden='true'>
                    <span style='width: 75%'></span>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Difficulty &amp; Responsibility</span>
                    <small>Easy</small>
                  </div>
                  <div class='balance-meter' aria-hidden='true'>
                    <span class='balance-marker' style='left: 90%'></span>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <div class='getting-started-choice' aria-hidden='true'>or</div>

          <article class='getting-started-card getting-started-secondary mos-panel'>
            <div class='getting-started-content getting-started-columns'>
              <div class='getting-started-main'>
                <h3 class='mos-card-title'>Choose your own server</h3>
                <p class='mos-body'>
                  Run the suite on your own server with a hosting provider you choose. This gives you more control and
                  flexibility, and a clearer path to long-term independence. It takes more time to set up, and you'll
                  need some technical comfort and occasional maintenance.
                </p>
                <a class='text-link mos-link' href='/docs/deploy-on-vps'>Learn about VPS</a>
              </div>

              <div class='getting-started-metrics'>
                <div class='metric metric-text'>
                  <div class='metric-head'>
                    <span>Setup time</span>
                    <strong><span class='metric-icon' aria-hidden='true'>◷</span> ~30-60 min</strong>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Privacy &amp; Control</span>
                    <small>85%</small>
                  </div>
                  <div class='continuous-meter' aria-hidden='true'>
                    <span style='width: 85%'></span>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Difficulty &amp; Responsibility</span>
                    <small>Slightly difficult</small>
                  </div>
                  <div class='balance-meter' aria-hidden='true'>
                    <span class='balance-marker' style='left: 42%'></span>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <div class='getting-started-choice' aria-hidden='true'>or</div>

          <article class='getting-started-card getting-started-tertiary mos-panel'>
            <div class='getting-started-content getting-started-columns'>
              <div class='getting-started-main'>
                <h3 class='mos-card-title'>Run it yourself</h3>
                <p class='mos-body'>
                  Run everything on your own hardware for full control and maximum privacy. Nothing depends on external
                  platforms, you are fully off the grid. This requires solid technical knowledge, especially around
                  networking and security, and you are responsible for keeping everything running safely.
                </p>
                <a class='text-link mos-link' href='/docs/deploy-on-your-own-hardware'>Explore self-hosting</a>
              </div>

              <div class='getting-started-metrics'>
                <div class='metric metric-text'>
                  <div class='metric-head'>
                    <span>Setup time</span>
                    <strong><span class='metric-icon' aria-hidden='true'>◷</span> Several hours+</strong>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Privacy &amp; Control</span>
                    <small>100%</small>
                  </div>
                  <div class='continuous-meter' aria-hidden='true'>
                    <span style='width: 100%'></span>
                  </div>
                </div>
                <div class='metric'>
                  <div class='metric-head'>
                    <span>Difficulty &amp; Responsibility</span>
                    <small>Very difficult</small>
                  </div>
                  <div class='balance-meter' aria-hidden='true'>
                    <span class='balance-marker' style='left: 6%'></span>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class='section how-section'>
        <div class='shell section-heading'>
          <span class='mos-eyebrow'>How it works</span>
          <h2 class='mos-section-title'>Choose a path, deploy the stack, and land inside your own suite.</h2>
        </div>

        <div class='shell step-grid'>
          {steps.map((step, index) => (
            <article class='step-card mos-panel'>
              <div class='step-number'>0{index + 1}</div>
              <h3 class='mos-card-title'>{step.title}</h3>
              <p class='mos-body'>{step.body}</p>
              <a class='text-link mos-link' href={step.href}>{step.label}</a>
            </article>
          ))}
        </div>
      </section>

      <section class='section philosophy-section'>
        <div class='shell philosophy-panel mos-panel'>
          <div class='philosophy-copy'>
            <span class='mos-eyebrow'>Why it feels different</span>
            <h2 class='mos-section-title'>Built around open apps, portability, and user control.</h2>
            <p class='mos-body'>
              The goal is not to mimic a closed SaaS platform with a different logo. The goal is to give you a
              stronger ownership boundary while still feeling like a real product you can actually use.
            </p>
          </div>

          <div class='principles-grid'>
            {principles.map((principle) => (
              <article class='principle-card'>
                <h3 class='mos-card-title'>{principle.title}</h3>
                <p class='mos-body'>{principle.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <MadeWithCarousel appLogos={appLogos} />

      <section class='section final-cta-section'>
        <div class='shell final-cta mos-panel'>
          <span class='mos-eyebrow'>Start here</span>
          <h2 class='mos-section-title'>Read the docs, pick a deploy path, and build the suite around your own rules.</h2>
          <p class='mos-body'>
            The homepage is the overview. The docs are where the real setup guidance, deploy options, and app details
            live.
          </p>
          <div class='final-actions'>
            <a class='mos-btn mos-btn-primary' href='/docs/getting-started'>Open getting started</a>
            <a class='mos-btn mos-btn-secondary' href={GITHUB_REPO_URL} target='_blank' rel='noreferrer'>
              Browse the repository
            </a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

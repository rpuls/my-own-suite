# ===========================================
# My-Own-Suite - Framework Configuration
# ===========================================
# Copy this file to .env and configure
# ===========================================

# Domain for all services (no protocol - just the domain)
# Local: localhost
# Production: yourdomain.com
DOMAIN=localhost

# Public URL protocol used for generated MOS app links.
# Use http with MOS_TLS_MODE=off, or https with MOS_TLS_MODE=cloudflare-dns01.
PUBLIC_URL_SCHEME=http

# TLS mode for MOS-managed Caddy routes.
# Supported values:
# - off: HTTP routes for normal local/VPS use, with Vaultwarden still using Caddy's internal HTTPS cert.
# - cloudflare-dns01: HTTPS routes using Caddy DNS-01 automation with Cloudflare.
MOS_TLS_MODE=off

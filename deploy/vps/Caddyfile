# ===========================================
# My-Own-Suite Caddyfile
# ===========================================
# Subdomain routing using DOMAIN from .env
# Local: homepage.mos.localhost, vaultwarden.mos.localhost
# Production: homepage.yourdomain.com, vaultwarden.yourdomain.com
# ===========================================

# Shared auth guard for public suite surfaces.
(authelia_guard) {
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# Authelia Portal
auth.{$DOMAIN} {
	reverse_proxy authelia:9091
}

# Homepage Dashboard
homepage.{$DOMAIN} {
	import authelia_guard
	reverse_proxy homepage:3000
}

# Suite Manager Onboarding
suite-manager.{$DOMAIN} {
	import authelia_guard
	reverse_proxy suite-manager:3000
}

# Vaultwarden Password Manager
vaultwarden.{$DOMAIN} {
	reverse_proxy vaultwarden:80
}

# Seafile File Sync
http://seafile.{$DOMAIN} {
	reverse_proxy seafile:80
}

# ONLYOFFICE Document Server
http://onlyoffice.{$DOMAIN} {
	reverse_proxy onlyoffice:80
}

# Stirling PDF Tools
http://stirling-pdf.{$DOMAIN} {
	reverse_proxy stirling-pdf:8080
}

# Radicale Calendar
http://radicale.{$DOMAIN} {
	reverse_proxy radicale:5232
}

# Immich Photos
http://immich.{$DOMAIN} {
	reverse_proxy immich:2283
}

# Internal Radicale iCal bridge for Homepage backend.
# This endpoint is for private network use only (homepage -> caddy),
# and keeps Radicale credentials out of Homepage widget URLs.
http://caddy {
	handle /internal/radicale-ical/{$RADICALE_ICAL_TOKEN} {
		rewrite * /{$RADICALE_ADMIN_USERNAME}/default-calendar/?export
		reverse_proxy radicale:5232 {
			header_up Authorization "Basic {$RADICALE_BASIC_AUTH_B64}"
		}
	}

	respond 404
}

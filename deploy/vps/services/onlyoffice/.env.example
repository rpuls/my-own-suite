# ===========================================
# OnlyOffice Configuration
# ===========================================
# Copy this file to .env and configure
# DOMAIN is loaded from root .env
# ===========================================

# Time zone used by the container
TZ=Europe/Amsterdam

# Allow callbacks/downloads to private or loopback addresses.
# Required for local development (localhost) and many private-network deployments.
ALLOW_PRIVATE_IP_ADDRESS=true

# JWT configuration.
# Keep disabled until you integrate with a document provider (e.g. Seafile).
JWT_ENABLED=false

# Set a long random secret before enabling JWT.
# Generate with: openssl rand -hex 32
JWT_SECRET=

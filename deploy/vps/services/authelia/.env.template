# ===========================================
# Authelia Configuration
# ===========================================

MOS_AUTHELIA_PUBLIC_URL=${{ url("auth", "https") }}
MOS_AUTHELIA_THEME=auto
MOS_AUTHELIA_SESSION_DOMAIN=${{ shared("DOMAIN") }}
MOS_AUTHELIA_OWNER_EMAIL=${{ shared("OWNER_EMAIL") }}
MOS_AUTHELIA_OWNER_PASSWORD=${{ shared("OWNER_PASSWORD") }}
MOS_AUTHELIA_OWNER_DISPLAY_NAME=${{ shared("OWNER_NAME") }}
MOS_AUTHELIA_SESSION_SECRET=${{ secret("authelia_session_secret", 48) }}
MOS_AUTHELIA_STORAGE_ENCRYPTION_KEY=${{ secret("authelia_storage_key", 64) }}
MOS_AUTHELIA_JWT_SECRET=${{ secret("authelia_jwt_secret", 48) }}
MOS_AUTHELIA_DATA_DIR=/data

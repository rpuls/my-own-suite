# ===========================================
# Seafile Configuration
# ===========================================
# Copy this file to .env and configure
# DOMAIN is loaded from root .env and constructed in docker-compose
# ===========================================

# MySQL root password (required by MySQL container)
# Generate with: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=

# MySQL root password (required by Seafile to connect to MySQL)
DB_ROOT_PASSWD=

# Database connection (Seafile -> MySQL)
DB_HOST=seafile-mysql
DB_PORT=3306
# MySQL grant host pattern for the generated 'seafile' user.
# Keep '%' for IPv4/IPv6 compatibility on cloud networks.
DB_USER_HOST=%

# Cache connection (Seafile -> Memcached)
MEMCACHED_SERVER=memcached:11211

# Seafile admin credentials
SEAFILE_ADMIN_EMAIL=
SEAFILE_ADMIN_PASSWORD=

# Public hostname for Seafile (no protocol)
SEAFILE_SERVER_HOSTNAME=

# Optional: Timezone (default: UTC)
TIME_ZONE=Europe/Amsterdam

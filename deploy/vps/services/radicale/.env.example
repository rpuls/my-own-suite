# ===========================================
# Radicale Configuration
# ===========================================
# Copy this file to .env and configure
# ===========================================

# Required: initial admin credentials
RADICALE_ADMIN_USERNAME=admin
RADICALE_ADMIN_PASSWORD=

# Required by Caddy internal iCal bridge for Homepage widget.
# Generate with:
#   printf '%s' 'admin:your-password' | base64
RADICALE_BASIC_AUTH_B64=

# Shared token for internal iCal bridge URL.
# Use a long random value.
RADICALE_ICAL_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

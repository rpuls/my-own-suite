# ===========================================
# Stirling PDF Configuration
# ===========================================

# Timezone used by the container
TZ=${{ shared("TIMEZONE") }}

# Keep the web UI in English by default
LANGS=en_GB

# Internal URL used by the application
SERVER_HOST=${{ url("stirling-pdf") }}

# Disable built-in analytics and consent prompts by default.
SYSTEM_ENABLEANALYTICS=false
SYSTEM_ENABLEPOSTHOG=false
SYSTEM_DISABLEPIXEL=true

# ===========================================
# Vaultwarden Configuration
# ===========================================

# Admin token for advanced administration
ADMIN_TOKEN=${{ secret("vaultwarden_admin_token", 48) }}

# Allow new user signups (set to false after creating your account)
SIGNUPS_ALLOWED=true

# Database connection (repo-managed Postgres service)
DATABASE_URL=postgresql://postgres:${{ secret("vaultwarden_pg_password", 32) }}@vaultwarden-postgres:5432/vaultwarden

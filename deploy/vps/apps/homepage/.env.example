# ===========================================
# Homepage Configuration
# ===========================================
# Copy this file to .env and configure
# DOMAIN is loaded from root .env
# ===========================================

# Allowed hosts for security (comma-separated)
# Uses DOMAIN from root .env, plus localhost fallback
HOMEPAGE_ALLOWED_HOSTS=homepage.${DOMAIN},localhost

# Service URLs (displayed on dashboard)
VAULTWARDEN_URL=http://vaultwarden.${DOMAIN}
SEAFILE_URL=http://seafile.${DOMAIN}
STIRLING_PDF_URL=http://stirling-pdf.${DOMAIN}
RADICALE_URL=http://radicale.${DOMAIN}
IMMICH_URL=http://immich.${DOMAIN}

# Calendar widget iCal feed (Radicale)
# This is fetched by Homepage backend, not the browser.
RADICALE_ICAL_URL=http://caddy/internal/radicale-ical/${{ secret("radicale_ical_token", 40, "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_") }}

# Add more services here as you add apps:
# NEXTCLOUD_URL=http://nextcloud.${DOMAIN}
# IMMICH_URL=http://immich.${DOMAIN}

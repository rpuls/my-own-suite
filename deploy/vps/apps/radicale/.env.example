# ===========================================
# Radicale Configuration
# ===========================================
# Copy this file to .env and configure
# ===========================================

# Required: initial admin credentials
RADICALE_ADMIN_USERNAME=admin
RADICALE_ADMIN_PASSWORD=${{ secret("radicale_admin_password", 24, "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_") }}

# Required by Caddy internal iCal bridge for Homepage widget.
RADICALE_BASIC_AUTH_B64=${{ base64("${RADICALE_ADMIN_USERNAME}:${RADICALE_ADMIN_PASSWORD}") }}

# Shared token for internal iCal bridge URL.
RADICALE_ICAL_TOKEN=${{ secret("radicale_ical_token", 40, "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_") }}

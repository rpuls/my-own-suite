# ===========================================
# Vaultwarden Configuration
# ===========================================
# Copy this file to .env and configure
# DOMAIN is loaded from root .env and constructed in docker-compose
# ===========================================

# Admin token for advanced administration
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=

# Allow new user signups (set to false after creating your account)
SIGNUPS_ALLOWED=true

# Database connection (repo-managed Postgres service)
# Use this default when running the `vaultwarden-postgres` service in this stack.
DATABASE_URL=postgresql://postgres:change-this-password@vaultwarden-postgres:5432/vaultwarden

# Postgres service credentials (for vaultwarden-postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=vaultwarden
